rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /avatars/{userId}_{timestamp} {
      allow read: if true; // Publicly readable avatars
      allow write: if request.auth != null && request.auth.uid == userId.split('_')[0];
    }
    match /wallpapers/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /wallpapers/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == fileName.split('_')[0];
    }
  }
}
