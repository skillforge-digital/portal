{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["html"],
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "no-undef": "error"
  },
  "globals": {
    "firebase": "readonly",
    "lucide": "readonly",
    "html2canvas": "readonly",
    "THREE": "readonly",
    "supabase": "readonly"
  }
}