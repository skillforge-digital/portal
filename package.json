{
  "name": "skillforge-portal",
  "version": "2.2.0",
  "type": "module",
  "description": "Enterprise Mastery Portal for SkillForge Digital",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "audit:security": "npm audit",
    "rules:deploy": "firebase deploy --only firestore:rules",
    "indexes:deploy": "firebase deploy --only firestore:indexes",
    "seed:staff": "node seed-staff.js"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0"
  },
  "devDependencies": {
    "vitest": "^1.4.0",
    "@vitest/coverage-v8": "^1.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-html": "^8.0.0",
    "jsdom": "^24.0.0"
  }
}