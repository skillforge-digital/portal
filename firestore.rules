rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isDirector() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/specialists/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/specialists/$(request.auth.uid)).data.level == 'Director';
    }
    
    function isSpecialist() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/specialists/$(request.auth.uid));
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Trainee Registry
    match /trainees/{traineeId} {
      allow read: if request.auth != null; // Allow all authenticated users to read
      allow list: if request.auth != null;
      allow create: if request.auth != null;
      
      // Update logic: Prevent unauthorized track changes if already set
      allow update: if request.auth != null && (
        isOwner(traineeId) || 
        resource.data.uid == request.auth.uid ||
        (!('uid' in resource.data) && request.resource.data.uid == request.auth.uid) ||
        true // Temporarily allow for director access until role-based is implemented
      );
      
      allow delete: if request.auth != null; // Temporarily allow for director access
    }
    
    // Presence & Tracking (Stricter Isolation)
    match /presence/{userId} {
      allow read: if request.auth != null; // Allow all authenticated users to read
      allow write: if isOwner(userId) && (
        // Rate limiting: Ensure pulses are at least 55 seconds apart to prevent multi-tab inflation
        !('server_lastActive' in resource.data) || 
        request.time > resource.data.server_lastActive + duration.value(55, 's')
      );
    }

    match /tracking/{userId} {
      allow read: if request.auth != null && (isOwner(userId) || isSpecialist());
      allow write: if isOwner(userId);
    }

    // Password Resets Subsystem
    match /password_resets/{requestId} {
      allow create: if true; // Anonymous requests allowed
      allow read: if isDirector();
      allow update: if true; // Allow token invalidation
    }

    // Email Dispatch (Trigger Email Extension)
    match /mail/{mailId} {
      allow create: if true; // Allowed for system-triggered emails
      allow read: if isDirector();
    }

    // Audit Logs (Stricter Create Logic)
    match /academy_audit_logs/{logId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if isDirector();
    }
    
    match /gate_audit_logs/{logId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if isDirector();
    }
    
    match /audit_logs/{logId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if isDirector();
    }

    // Feedback Collection
    match /feedback/{feedbackId} {
      allow create: if true; // Anonymous feedback allowed
      allow read: if isSpecialist();
    }

    // Specialist Registry
    match /specialists/{specialistId} {
      allow read: if request.auth != null;
      allow create: if isDirector();
      allow update, delete: if isDirector();
    }

    // System & Seasons
    match /system/{docId} {
      allow read: if true;
      allow write: if isDirector();
    }
    
    match /seasons/{seasonId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if isDirector();
      
      // Exception for counters during registration
      match /artifacts/trainees/counters/tracks {
        allow read, write: if request.auth != null;
      }
    }

    // Announcements & News
    match /announcements/{announcementId} {
      allow read, list: if true;
      allow write: if isSpecialist();
    }
  }
}
