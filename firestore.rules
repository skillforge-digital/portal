rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // SKILLFORGE DIGITAL ACADEMY: UNIFIED SECURITY SHIELD (v4.0)
    // =========================================================================
    // DESIGN PHILOSOPHY:
    // 1. SIMPLE & ROBUST: Use clear, centralized role checking.
    // 2. BACKWARD COMPATIBLE: Support legacy mock IDs & existing collections.
    // 3. SCALABLE: Unified 'staffs' collection with multi-role support.
    // 4. GRACEFUL: Frictionless access for registration and local development.
    // =========================================================================

    // --- 1. CORE AUTH & ROLE HELPERS ---
    
    // Checks if the request is authenticated via Firebase Auth.
    function isAuthenticated() { return request.auth != null; }
    
    // Gets the current user's UID.
    function getUID() { return request.auth.uid; }

    function isLegacyDirector() { return isAuthenticated() && exists(/databases/$(database)/documents/directors/$(getUID())); }
    function isLegacyHOD() { return isAuthenticated() && exists(/databases/$(database)/documents/hods/$(getUID())); }
    function isLegacySpecialist() { return isAuthenticated() && exists(/databases/$(database)/documents/specialists/$(getUID())); }
    
    // Unified Staff Role Check: Looks up roles in the centralized 'staffs' collection.
    // Returns true if the user has ANY of the specified roles. Supports legacy single 'role'.
    function hasAnyRole(roles) {
      let staffDoc = get(/databases/$(database)/documents/staffs/$(getUID()));
      return isAuthenticated() && 
             staffDoc != null &&
             staffDoc.data.status == 'active' &&
             (
               staffDoc.data.get('roles', []).hasAny(roles) ||
               (staffDoc.data.get('role', '') in roles)
             );
    }

    // Role-specific helpers for common permission checks.
    function isDirector() { return hasAnyRole(['Director']) || isLegacyDirector(); }
    function isHOD() { return hasAnyRole(['Director', 'HOD']) || isLegacyDirector() || isLegacyHOD(); }
    function isSpecialist() { return hasAnyRole(['Director', 'HOD', 'Specialist']) || isLegacyDirector() || isLegacyHOD() || isLegacySpecialist(); }
    function isStaff() { return hasAnyRole(['Director', 'HOD', 'Specialist', 'Support Staff', 'Support Team', 'Support Staff / Team', 'Digital Marketing', 'Community Manager', 'Staff']) || isLegacyDirector() || isLegacyHOD() || isLegacySpecialist(); }
    
    // Checks if the user is the owner of the document.
    function isOwner(userId) { return isAuthenticated() && getUID() == userId; }

    // =========================================================================
    // 2. USER & IDENTITY COLLECTIONS
    // =========================================================================
    
    // Trainee Registry: Stores profiles, XP, and learning state.
    match /trainees/{traineeId} {
      // Robust Read/Write: Allows legacy mock reconciliation and cloud migration.
      // Explicitly allow list operations for leaderboard and directory.
      allow get: if isOwner(traineeId) || isStaff();
      allow list: if isStaff();
      allow create: if isAuthenticated() && request.auth.uid == traineeId; // Must be authenticated as the trainee
      // Owners can update their profile but cannot manipulate their XP or Level. Only Staff can grant XP.
      allow update: if (isOwner(traineeId) && request.resource.data.get('xp', 0) == resource.data.get('xp', 0)) || isStaff();
      allow delete: if isDirector();
    }

    // Unified Staff Registry: Stores personnel data and cumulative roles.
    match /staffs/{staffId} {
      // Staff can see each other; public can read for verification.
      allow get: if isOwner(staffId) || isStaff();
      allow list: if isStaff();
      // Allow self-registration if authenticated; FORCE status to be 'pending' to prevent privilege escalation.
      allow create: if (isAuthenticated() && request.auth.uid == staffId && request.resource.data.status == 'pending') || isDirector();
      allow delete: if isDirector();
      // Owners can update their profile but cannot change their role, roles, or status. Only Directors can elevate privileges.
      allow update: if (isOwner(staffId) && request.resource.data.status == resource.data.status && request.resource.data.get('role', '') == resource.data.get('role', '') && request.resource.data.get('roles', []) == resource.data.get('roles', [])) || isDirector();
    }

    // LEGACY COMPATIBILITY: Support for old collection-based role documents.
    match /directors/{uid} { allow read: if isOwner(uid) || isDirector(); allow write: if isDirector(); }
    match /hods/{uid} { allow read: if isOwner(uid) || isHOD(); allow write: if isHOD(); }
    match /specialists/{uid} { allow read: if isOwner(uid) || isSpecialist(); allow write: if isSpecialist(); }

    // =========================================================================
    // 3. ACADEMY INFRASTRUCTURE
    // =========================================================================

    // Academy Gate & SSO Backbone: O(1) PIN/Passkey lookup for entry.
    // This MUST remain publicly readable to allow auto-auth from the Main Site.
    match /track_access/{pin} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isStaff();
    }

    // Role Codes: One-time use codes for staff onboarding.
    match /staffAccessCodes/{code} {
      allow get: if true;
      allow list: if isDirector();
      allow create: if isDirector();
      allow update: if isDirector() ||
        (isAuthenticated() &&
         resource.data.used == false &&
         request.resource.data.used == true &&
         request.resource.data.usedBy == request.auth.uid &&
         request.resource.data.get('roles', []) == resource.data.get('roles', []));
      allow delete: if isDirector();
    }

    match /role_codes/{code} {
      // Relaxed rules for development: allow onboarding verification.
      allow get: if true;
      allow list: if isStaff();
      allow create: if isDirector();
      allow update: if isDirector() ||
        (isAuthenticated() &&
         resource.data.used == false &&
         request.resource.data.used == true &&
         request.resource.data.usedBy == request.auth.uid &&
         request.resource.data.status == 'pending' &&
         request.resource.data.get('name', '') == resource.data.get('name', '') &&
         request.resource.data.get('position', '') == resource.data.get('position', '') &&
         request.resource.data.get('roles', []) == resource.data.get('roles', []));
      allow delete: if isDirector();
    }

// System Config: Current season and global settings.
    match /system/{docId} {
      allow read: if true;
      allow write: if isDirector();
    }
    
    // Global Wallpaper Storage
    match /system/public_wallpapers {
      allow read: if true;
      allow update, create: if isAuthenticated();
    }

    // Seasons & Archives: Enrollment data and past generations.
    match /seasons/{seasonId} {
      allow read: if true;
      allow write: if isStaff();
      
      // Allow trainees to update track counters during registration
      match /artifacts/trainees/counters/tracks {
        allow read, write: if true;
      }
      
      // Allow general registration artifacts (referrals, stats, etc)
      match /artifacts/registration/{docId} {
        allow read, write: if true;
      }
      
      match /{document=**} { allow read: if true; allow write: if isStaff(); }
    }

    // Password Management & SSO
    match /password_resets/{id} {
      allow create: if
        request.resource.data.keys().hasAll(['ticketCode', 'email', 'phone', 'accountType', 'status']) &&
        request.resource.data.ticketCode is string &&
        request.resource.data.ticketCode.size() == 6 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 0 &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() > 0 &&
        request.resource.data.accountType in ['trainee', 'staff'] &&
        request.resource.data.status == 'requested';
      allow read, update, delete: if isStaff();
    }
    match /academy_audit_logs/{id} { allow read: if isStaff(); allow create: if true; }
    match /gate_audit_logs/{id} { allow read: if isStaff(); allow create: if true; }

    // =========================================================================
    // 4. TELEMETRY & LOGS (Publicly Writable, Restricted Read)
    // =========================================================================

    match /presence/{userId} { allow read: if true; allow write: if true; }
    match /tracking/{userId} { allow read: if true; allow write: if true; }
    match /system_faults/{id} { allow read: if isStaff(); allow create: if true; }
    match /audit_logs/{id} { allow read: if isStaff(); allow create: if true; }
    match /registry_admin_logs/{id} { allow read, create: if isStaff(); allow update, delete: if isDirector(); }
    match /staff_activity_global/{id} { allow read: if isStaff(); allow create: if isStaff(); }
    match /staff_activity_units/{unit}/entries/{id} { allow read: if isStaff(); allow create: if isStaff(); }

    // =========================================================================
    // 5. COMMUNICATIONS & SOCIAL
    // =========================================================================

    match /announcements/{id} { allow read: if true; allow write: if isStaff(); }
    match /mail/{id} { allow read, write: if isAuthenticated(); }
    match /feedback/{id} { allow read: if isStaff(); allow create: if true; }
    match /badge_requests/{id} { 
      allow read: if isStaff() || isOwner(request.resource.data.userId) || isOwner(resource.data.userId);
      allow create: if isAuthenticated();
      allow update: if isStaff();
    }

    // =========================================================================
    // 6. SAFETY NET (TIGHTENED)
    // =========================================================================
    match /{document=**} {
      // Default: Block everything else by default
      allow read, write: if isDirector();
    }
  }
}
