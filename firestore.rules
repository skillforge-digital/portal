rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic auth check
    function isAuthenticated() {
      return request.auth != null;
    }

    // Trainees collection
    match /trainees/{userId} {
      // allow get/list for profile lookup and leaderboard
      allow get, list: if isAuthenticated();
      
      // Allow creation during registration
      allow create: if isAuthenticated();
      
      // Allow update for profile correction and dashboard updates
      // In a real production app, we would use a more secure method to verify identity
      allow update: if isAuthenticated();
      
      allow delete: if false;
    }

    // Real-time presence and session tracking
    match /presence/{userId} {
      allow read, write: if isAuthenticated();
    }

    // Seasons and counters for trainee IDs
    match /seasons/{seasonId}/{documents=**} {
      allow read, write: if isAuthenticated();
    }

    // Global config and wallpapers
    match /global_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /wallpapers/{wallpaperId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if false;
    }
    
    // Audit logs
    match /audit_logs/{logId} {
      allow create, read: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
