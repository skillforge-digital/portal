rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Trainee Registry
    match /trainees/{traineeId} {
      allow read, list: if request.auth != null;
      
      // Allow creation during registration
      allow create: if request.auth != null;
      
      // Robust Write Logic:
      // 1. User owns the document (UID matches ID)
      // 2. User has already claimed it (UID field matches session)
      // 3. LEGACY CLAIM: Document exists but has no UID, and user is adding their UID
      allow update: if request.auth != null && (
        request.auth.uid == traineeId || 
        resource.data.uid == request.auth.uid ||
        (!('uid' in resource.data) && request.resource.data.uid == request.auth.uid)
      );
      
      allow delete: if false; // Data is immutable for trainees
    }
    
    // Presence Registry
    match /presence/{userId} {
      allow read, list: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId || 
        resource.data.uid == request.auth.uid ||
        (!('uid' in resource.data) && request.resource.data.uid == request.auth.uid)
      );
    }

    // Analytics & Tracking
    match /tracking/{userId} {
      allow read, list: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId || 
        resource.data.uid == request.auth.uid ||
        (!('uid' in resource.data) && request.resource.data.uid == request.auth.uid)
      );
    }
    
    // System Configuration
    match /system/{docId} {
      allow read: if true;
      allow write: if get(/databases/$(database)/documents/specialists/$(request.auth.uid)).data.level == 'Director';
    }
    
    // Specialist Registry
    match /specialists/{specialistId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null; // Managed by activate-specialist logic
      allow update, delete: if false; // Immutable once authorized
    }
    
    // Audit Logs
    match /audit_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if get(/databases/$(database)/documents/specialists/$(request.auth.uid)).data.level == 'Director';
    }
    
    // Badge Requests
    match /badge_requests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if exists(/databases/$(database)/documents/specialists/$(request.auth.uid));
    }
    
    // Season Artifacts & Registry Counters
    match /seasons/{seasonId}/{document=**} {
      allow read: if request.auth != null;
      
      // Allow trainees to update the registration counter specifically
      match /artifacts/trainees/counters/tracks {
        allow read, write: if request.auth != null;
      }
      
      // All other season writes restricted to Directors
      allow write: if get(/databases/$(database)/documents/specialists/$(request.auth.uid)).data.level == 'Director';
    }

    // Announcements & News
    match /announcements/{announcementId} {
      allow read, list: if true;
      allow write: if exists(/databases/$(database)/documents/specialists/$(request.auth.uid));
    }
  }
}
