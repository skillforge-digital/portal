rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    match /trainees/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /presence/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    match /tracking/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /specialists/{userId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only manageable via Firebase Console or special script
    }

    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isSpecialist();
    }

    match /seasons/{seasonId}/{documents=**} {
      allow read, write: if isAuthenticated();
    }

    match /global_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /wallpapers/{wallpaperId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if false;
    }
    
    match /audit_logs/{logId} {
      allow create, read: if isAuthenticated();
      allow update, delete: if false;
    }
    
    function isSpecialist() {
      return isAuthenticated() && exists(/databases/$(database)/documents/specialists/$(request.auth.uid));
    }

    match /badge_requests/{requestId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update: if isSpecialist();
      allow delete: if false;
    }
    
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if false; // Strict fallback
    }
  }
}
