rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Trainee Registry
    match /trainees/{traineeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == traineeId;
      // Allow creation during registration
      allow create: if request.auth != null;
    }
    
    // Presence Registry
    match /presence/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // System Configuration
    match /system/{docId} {
      allow read: if true;
      allow write: if get(/databases/$(database)/documents/specialists/$(request.auth.uid)).data.level == 'Director';
    }
    
    // Specialist Registry
    match /specialists/{specialistId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null; // Managed by activate-specialist logic
      allow update, delete: if false; // Immutable once authorized
    }
    
    // Audit Logs
    match /audit_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if get(/databases/$(database)/documents/specialists/$(request.auth.uid)).data.level == 'Director';
    }
    
    // Badge Requests
    match /badge_requests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if exists(/databases/$(database)/documents/specialists/$(request.auth.uid));
    }
    
    // Season Artifacts
    match /seasons/{seasonId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if get(/databases/$(database)/documents/specialists/$(request.auth.uid)).data.level == 'Director';
    }

    // Announcements & News
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if exists(/databases/$(database)/documents/specialists/$(request.auth.uid));
    }
  }
}
