rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================

    function isAuthenticated() {
      return request.auth != null;
    }

    // ==================== OPERATIONAL RULES (V2) ====================
    // These rules are designed for cross-platform consistency and "Mock UID" support.
    // They allow all authenticated sessions (including anonymous) to:
    // 1. Read all core data (necessary for Director Hub listing and Trainee login).
    // 2. Write to their own profiles and manage registry data.

    // Core Registries (Trainees, Staff, Specialists, etc.)
    match /trainees/{id} {
      allow read, write: if isAuthenticated();
    }
    match /staffs/{id} {
      allow read, write: if isAuthenticated();
    }
    match /specialists/{id} {
      allow read, write: if isAuthenticated();
    }
    match /hods/{id} {
      allow read, write: if isAuthenticated();
    }
    match /directors/{id} {
      allow read, write: if isAuthenticated();
    }

    // Academy Infrastructure (Seasons, Config, etc.)
    match /seasons/{id} {
      allow read, write: if isAuthenticated();
      match /{document=**} {
        allow read, write: if isAuthenticated();
      }
    }
    match /system/{id} {
      allow read, write: if isAuthenticated();
    }
    match /role_codes/{id} {
      allow read, write: if isAuthenticated();
    }
    match /track_access/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Activity & Presence
    match /presence/{id} {
      allow read, write: if isAuthenticated();
    }
    match /tracking/{id} {
      allow read, write: if isAuthenticated();
    }
    match /audit_logs/{id} {
      allow read, write: if isAuthenticated();
    }
    match /academy_audit_logs/{id} {
      allow read, write: if isAuthenticated();
    }
    match /gate_audit_logs/{id} {
      allow read, write: if isAuthenticated();
    }
    match /staff_audit_logs/{id} {
      allow read, write: if isAuthenticated();
    }

    // Communication & Community
    match /announcements/{id} {
      allow read, write: if isAuthenticated();
    }
    match /feedback/{id} {
      allow read, write: if isAuthenticated();
    }
    match /badge_requests/{id} {
      allow read, write: if isAuthenticated();
    }
    match /mail/{id} {
      allow read, write: if true; // Public contact form
    }
    match /password_resets/{id} {
      allow read, write: if true; // Public forgot password flow
    }

    // ==================== CATCH-ALL ====================
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
