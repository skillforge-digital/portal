rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Staff role helpers — check multiple collections for cross-compatibility
    function inSpecialists() {
      return exists(/databases/$(database)/documents/specialists/$(request.auth.uid));
    }

    function inHODs() {
      return exists(/databases/$(database)/documents/hods/$(request.auth.uid));
    }

    function inDirectors() {
      return exists(/databases/$(database)/documents/directors/$(request.auth.uid));
    }

    function inStaffs() {
      return exists(/databases/$(database)/documents/staffs/$(request.auth.uid));
    }

    // Any staff role: specialist, HOD, or Director
    function isStaff() {
      return isAuthenticated() && (inSpecialists() || inHODs() || inDirectors() || inStaffs());
    }

    // HOD level — can manage their department
    function isHOD() {
      return isAuthenticated() && (
        inHODs() ||
        (inSpecialists() && get(/databases/$(database)/documents/specialists/$(request.auth.uid)).data.level == 'HOD')
      );
    }

    // Director level — full admin
    function isDirector() {
      return isAuthenticated() && (
        inDirectors() ||
        (inSpecialists() && get(/databases/$(database)/documents/specialists/$(request.auth.uid)).data.level == 'Director')
      );
    }

    // Rate-limit helper — true if 55 seconds have passed since last write
    function notRateLimited() {
      return !('server_lastActive' in resource.data) ||
        request.time > resource.data.server_lastActive + duration.value(55, 's');
    }

    // ==================== TRACK ACCESS (PIN-Based Academy Gate) ====================
    // Doc ID = the 6-digit PIN. Public read so gate can verify without auth.
    // Client write is blocked — only server-side registration transaction should write.

    match /track_access/{pin} {
      allow read: if true;
      allow write: if false;
    }

    // ==================== SYSTEM CONFIG ====================
    // Global app config. Public read needed for registration to fetch settings.

    match /system/{docId} {
      allow read: if true;
      allow write: if isDirector();
    }

    // ==================== STAFF ONBOARDING CODES ====================
    // Role codes for staff registration. Public read so anyone can use them to register.

    match /role_codes/{codeId} {
      allow read: if true;
      allow create, update, delete: if isDirector();
    }

    // ==================== UNIFIED STAFF REGISTRY ====================

    match /staffs/{staffId} {
      allow read: if isAuthenticated() && (isOwner(staffId) || isStaff());
      allow create: if request.auth != null;
      allow update: if isOwner(staffId) || isDirector();
      allow delete: if isDirector();
    }

    // ==================== STAFF AUDIT LOGS ====================

    match /staff_audit_logs/{logId} {
      allow read: if isDirector();
      allow create: if isStaff();
    }

    // ==================== TRAINEE REGISTRY ====================
    // Core trainee records. Each trainee owns their doc.
    // Staff (specialist/HOD/Director) can list and read all for management.
    // Only Directors can delete trainee accounts.

    match /trainees/{traineeId} {
      allow read: if isAuthenticated() && isOwner(traineeId);
      allow list: if isAuthenticated(); // Registry is viewable by all members
      allow create: if request.auth != null && isOwner(traineeId);
      allow update: if isOwner(traineeId) || isStaff();
      allow delete: if isDirector();
    }

    // ==================== PRESENCE (Online Status) ====================
    // Rate-limited to prevent spam. Public read so staff can see who's online.

    match /presence/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && notRateLimited();
    }

    // ==================== ACTIVITY TRACKING ====================
    // Trainees track their own activity. Staff can read to view progress.

    match /tracking/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow write: if isOwner(userId);
    }

    // ==================== SPECIALISTS (Standalone) ====================
    // Specialists own their profile and can update it. Directors manage them.

    match /specialists/{specialistId} {
      allow read: if isAuthenticated() && (isOwner(specialistId) || isStaff());
      allow create: if request.auth != null;
      allow update: if isDirector() || isOwner(specialistId);
      allow delete: if isDirector();
    }

    // ==================== HODs (Standalone) ====================

    match /hods/{hodId} {
      allow read: if isAuthenticated() && (isOwner(hodId) || isStaff());
      allow create: if request.auth != null;
      allow update: if isDirector() || isOwner(hodId);
      allow delete: if isDirector();
    }

    // ==================== DIRECTORS (Standalone) ====================
    // Directors can update their own profile. Cannot be deleted by client.

    match /directors/{directorId} {
      allow read: if isAuthenticated() && (isOwner(directorId) || isDirector());
      allow create: if request.auth != null;
      allow update: if isDirector() || isOwner(directorId);
      allow delete: if false;
    }

    // ==================== SEASONS & ARCHIVES ====================
    // Seasons store per-season trainee data. Authenticated can read tracks counter.
    // Only Directors can write season data and archives.

    match /seasons/{seasonId} {
      allow read: if true; // Public read needed for gate logic
      allow write: if isDirector();

      match /artifacts/trainees/counters/tracks {
        allow read: if true; // Public read needed for enrollment UI
        allow write: if isAuthenticated(); // Used in registration transaction
      }

      match /{document=**} {
        allow read: if isAuthenticated();
        allow write: if isDirector();
      }
    }

    match /season_archives/{seasonId} {
      allow read: if isDirector();
      allow create, delete: if isDirector();
    }

    // ==================== ANNOUNCEMENTS ====================
    // Public read. Staff can create. Only creator or Director can update. Director deletes.

    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if isStaff();
      allow update: if isStaff() && (
        isDirector() ||
        resource.data.postedByUid == request.auth.uid
      );
      allow delete: if isDirector();
    }

    // ==================== FEEDBACK ====================
    // Any authenticated user can submit. Staff can read and update (reply/resolve).

    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read, update: if isStaff();
    }

    // ==================== BADGE REQUESTS ====================
    // Any authenticated user can request a badge. Staff can read and process.

    match /badge_requests/{requestId} {
      allow read: if isStaff();
      allow create: if isAuthenticated();
      allow update: if isDirector() || isSpecialist();
    }

    // ==================== AUDIT LOGS ====================
    // Users can only create logs with their own uid. Directors can read all.

    match /audit_logs/{logId} {
      allow create: if isAuthenticated() &&
        request.resource.data.uid == request.auth.uid;
      allow read: if isDirector();
    }

    match /academy_audit_logs/{logId} {
      allow create: if isAuthenticated() &&
        request.resource.data.uid == request.auth.uid;
      allow read: if isDirector();
    }

    match /gate_audit_logs/{logId} {
      allow create: if isAuthenticated() &&
        request.resource.data.uid == request.auth.uid;
      allow read: if isDirector();
    }

    // ==================== EMAIL DISPATCH ====================
    // Public form to create a mail doc. Directors can read dispatched emails.

    match /mail/{mailId} {
      allow create: if true;
      allow read: if isDirector();
    }

    // ==================== PASSWORD RESETS ====================
    // Anyone can create a reset request (forgot password flow).
    // User updates via token link (update with token). Director can read.

    match /password_resets/{requestId} {
      allow create: if true;
      allow read: if isDirector();
      allow update: if true; // Token-based update by the user
    }

    // ==================== CATCH-ALL ====================
    // Deny everything not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
