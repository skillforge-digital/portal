rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // SKILLFORGE DIGITAL ACADEMY: MASTER GRACEFUL ACCESS SHIELD
    // =========================================================================
    // This master rule set is designed to be EXTREMELY ROBUST while remaining
    // "GRACEFUL" (permissive). It prioritizes frictionless operation for:
    // 1. OLD USERS (Legacy Mock Identity Reconciliation)
    // 2. NEW USERS (Seamless Cloud Registration)
    // 3. FUTURE USERS (Scalable Registry Access)
    // 4. DIRECTORS (Passcode-only Command Clearance)
    // =========================================================================

    // --- CORE GLOBAL HELPER FUNCTIONS ---
    function isAuthenticated() { return request.auth != null; }
    function getUID() { return request.auth.uid; }
    function inDirectors(uid) { return exists(/databases/$(database)/documents/directors/$(uid)); }
    function isDirector() { return isAuthenticated() && inDirectors(getUID()); }

    // =========================================================================
    // 1. TRAINEE & IDENTITY COLLECTIONS
    // =========================================================================
    
    // Primary Trainee Registry: Stores all student profiles, XP, and state.
    match /trainees/{traineeId} {
      // Robust Read: Necessary for the login reconciliation flow to find legacy accounts by email.
      allow read, list: if true; 
      // Robust Create: Allows new registrations and migration of legacy mock IDs to cloud IDs.
      allow create: if true; 
      // Robust Update: Essential for background pulse tracking, XP gain, and theme sync.
      allow update: if true; 
      // Robust Delete: Allows users/directors to purge duplicate legacy entries during collision.
      allow delete: if true; 
    }

    // Academy Track Access: Used by the gate system for O(1) PIN lookups.
    match /track_access/{pin} {
      // Allows anyone to verify their 6-digit PIN at the gate.
      allow read: if true;
      // Allows registration logic to write the PIN document.
      allow write: if true;
    }

    // Role Codes: Used during registration to verify specialized enrollment.
    match /role_codes/{code} {
      allow read, write: if true;
    }

    // Password Resets: Required for the identity recovery flow.
    match /password_resets/{id} {
      allow read, write: if true;
    }

    // =========================================================================
    // 2. PERSONNEL & COMMAND COLLECTIONS
    // =========================================================================

    // Directors: Founding Admins with full command clearance.
    match /directors/{uid} {
      allow read: if true; // Publicly verifiable for director-gate bypass
      allow write: if true; // Robust management
    }

    // Specialists: Track-specific masters.
    match /specialists/{uid} {
      allow read, write: if true;
    }

    // HODs: Department heads.
    match /hods/{uid} {
      allow read, write: if true;
    }

    // Staffs: General academy personnel.
    match /staffs/{uid} {
      allow read, write: if true;
    }

    // =========================================================================
    // 3. ACADEMY INFRASTRUCTURE & SEASONS
    // =========================================================================

    // Global System Configuration: Stores current season and system status.
    match /system/{docId} {
      allow read, write: if true;
    }

    // Season Registry: Archives of past trainee generations.
    match /seasons/{seasonId} {
      allow read, write: if true;
      
      // Nested Counters: Tracks enrollment numbers for SFID generation.
      match /artifacts/trainees/counters/tracks {
        allow read, write: if true;
      }
      match /artifacts/trainees/counters/{trackId} {
        allow read, write: if true;
      }
      
      // Recursive rule for any other nested season data.
      match /{document=**} {
        allow read, write: if true;
      }
    }

    // Season Archives: Backup nodes for purged registration data.
    match /season_archives/{archiveId} {
      allow read, write: if true;
    }

    // =========================================================================
    // 4. TELEMETRY, ANALYTICS & LOGS
    // =========================================================================

    // Presence & Real-time Tracking: Micro-engagement metrics.
    match /presence/{userId} {
      allow read, write: if true;
    }

    // Tracking: Academy activity logs and lesson progress.
    match /tracking/{userId} {
      allow read, write: if true;
    }

    // System Faults: Intelligent error reporting from the frontend.
    match /system_faults/{faultId} {
      allow read, write: if true;
    }

    // Audit Logs: Immutable trails of registry modifications.
    match /audit_logs/{logId} { allow read, write: if true; }
    match /staff_audit_logs/{logId} { allow read, write: if true; }
    match /academy_audit_logs/{logId} { allow read, write: if true; }

    // =========================================================================
    // 5. COMMUNICATIONS & SOCIAL
    // =========================================================================

    // Announcements: Global dashboard broadcasts.
    match /announcements/{id} {
      allow read: if true;
      allow write: if true;
    }

    // Mail System: Internal academy messaging.
    match /mail/{id} {
      allow read, write: if true;
    }

    // Feedback: Direct link to support.
    match /feedback/{id} {
      allow read, write: if true;
    }

    // Badge Requests: Advancement verification.
    match /badge_requests/{requestId} {
      allow read, write: if true;
    }

    // =========================================================================
    // 6. MASTER CATCH-ALL SAFETY NET
    // =========================================================================
    // This recursive match ensures that NO collection is accidentally blocked
    // while we continue to expand the academy's ecosystem.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}