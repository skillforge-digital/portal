rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic auth check
    function isAuthenticated() {
      return request.auth != null;
    }

    // Ownership check
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Trainees collection: Essential for dashboard and leaderboard
    match /trainees/{userId} {
      // Allow individual read for dashboard sync
      allow get: if isAuthenticated() && isOwner(userId);
      
      // Allow listing for the Hall of Fame (Leaderboard)
      // Note: In production, consider a cloud function to strip sensitive data
      allow list: if isAuthenticated();
      
      // Strict write permissions
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && isOwner(userId);
      allow delete: if false; // Prevent accidental account deletion from UI
    }

    // Registry logs: for tracking mastery and XP changes
    match /audit_logs/{logId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Real-time presence and session tracking
    match /presence/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    // Seasons and counters for trainee IDs
    match /seasons/{seasonId}/{documents=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Needed for incrementing counters during registration
    }

    // Global assets and configuration (e.g., registry counters)
    match /global_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // System only
    }

    // Global Wallpapers: shared registry for all trainees
    match /wallpapers/{wallpaperId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Allow any trainee to contribute to global gallery
      allow update, delete: if false; // Prevent modification or deletion by other users
    }
  }
}