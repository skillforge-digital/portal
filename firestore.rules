rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isStaff() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/staffs/$(request.auth.uid));
    }

    function getStaffData() {
      return get(/databases/$(database)/documents/staffs/$(request.auth.uid)).data;
    }

    function isDirector() {
      return request.auth != null && (
        (exists(/databases/$(database)/documents/specialists/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/specialists/$(request.auth.uid)).data.level == 'Director') ||
        (exists(/databases/$(database)/documents/staffs/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/staffs/$(request.auth.uid)).data.primaryRole == 'Director')
      );
    }
    
    function isSpecialist() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/specialists/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/staffs/$(request.auth.uid)) && 
         'Specialist' in get(/databases/$(database)/documents/staffs/$(request.auth.uid)).data.roles)
      );
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ROLE Codes Subsystem
    match /role_codes/{codeId} {
      allow read: if true; // Required for verification during registration
      allow write: if isDirector();
    }

    // Staff Registry
    match /staffs/{staffId} {
      allow read: if request.auth != null && (isOwner(staffId) || isStaff());
      allow create: if request.auth != null;
      allow update: if isOwner(staffId) || isDirector();
      allow delete: if isDirector();
    }

    // Trainee Registry
    match /trainees/{traineeId} {
      allow read: if request.auth != null; 
      allow list: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        isOwner(traineeId) || 
        resource.data.uid == request.auth.uid ||
        isStaff()
      );
      allow delete: if isDirector();
    }
    
    // Presence & Tracking
    match /presence/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId) && (
        !('server_lastActive' in resource.data) || 
        request.time > resource.data.server_lastActive + duration.value(55, 's')
      );
    }

    match /tracking/{userId} {
      allow read: if request.auth != null && (isOwner(userId) || isStaff());
      allow write: if isOwner(userId);
    }

    // Password Resets Subsystem
    match /password_resets/{requestId} {
      allow create: if true;
      allow read: if isDirector();
      allow update: if true;
    }

    // Email Dispatch
    match /mail/{mailId} {
      allow create: if true;
      allow read: if isDirector();
    }

    // Audit Logs
    match /academy_audit_logs/{logId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if isDirector();
    }
    
    match /gate_audit_logs/{logId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if isDirector();
    }
    
    match /audit_logs/{logId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if isDirector();
    }

    // Feedback Collection
    match /feedback/{feedbackId} {
      allow create: if true;
      allow read: if isStaff();
    }

    // Specialist Registry (Legacy Support)
    match /specialists/{specialistId} {
      allow read: if request.auth != null;
      allow create: if isDirector();
      allow update, delete: if isDirector();
    }

    // System & Seasons
    match /system/{docId} {
      allow read: if true;
      allow write: if isDirector();
    }
    
    match /seasons/{seasonId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if isDirector();
      
      match /artifacts/trainees/counters/tracks {
        allow read, write: if request.auth != null;
      }
    }

    // Announcements & News
    match /announcements/{announcementId} {
      allow read, list: if true;
      allow write: if isStaff();
    }
  }
}
