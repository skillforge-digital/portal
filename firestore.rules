rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // SKILLFORGE DIGITAL ACADEMY: UNIFIED SECURITY SHIELD (v4.0)
    // =========================================================================
    // DESIGN PHILOSOPHY:
    // 1. SIMPLE & ROBUST: Use clear, centralized role checking.
    // 2. BACKWARD COMPATIBLE: Support legacy mock IDs & existing collections.
    // 3. SCALABLE: Unified 'staffs' collection with multi-role support.
    // 4. GRACEFUL: Frictionless access for registration and local development.
    // =========================================================================

    // --- 1. CORE AUTH & ROLE HELPERS ---
    
    // Checks if the request is authenticated via Firebase Auth.
    function isAuthenticated() { return request.auth != null; }
    
    // Gets the current user's UID.
    function getUID() { return request.auth.uid; }
    
    // Unified Staff Role Check: Looks up roles in the centralized 'staffs' collection.
    // Returns true if the user has ANY of the specified roles.
    function hasAnyRole(roles) {
      let staffDoc = get(/databases/$(database)/documents/staffs/$(getUID()));
      return isAuthenticated() && 
             staffDoc != null &&
             staffDoc.data.status == 'active' &&
             staffDoc.data.roles.hasAny(roles);
    }

    // Role-specific helpers for common permission checks.
    function isDirector() { return hasAnyRole(['Director']); }
    function isHOD() { return hasAnyRole(['Director', 'HOD']); }
    function isSpecialist() { return hasAnyRole(['Director', 'HOD', 'Specialist']); }
    function isStaff() { return isAuthenticated() && exists(/databases/$(database)/documents/staffs/$(getUID())); }
    
    // Checks if the user is the owner of the document.
    function isOwner(userId) { return isAuthenticated() && getUID() == userId; }

    // =========================================================================
    // 2. USER & IDENTITY COLLECTIONS
    // =========================================================================
    
    // Trainee Registry: Stores profiles, XP, and learning state.
    match /trainees/{traineeId} {
      // Robust Read/Write: Allows legacy mock reconciliation and cloud migration.
      // Explicitly allow list operations for leaderboard and directory.
      allow read, get, list: if true;
      allow create: if true; // Registration is open
      allow update: if isOwner(traineeId) || isStaff();
      allow delete: if isDirector();
    }

    // Unified Staff Registry: Stores personnel data and cumulative roles.
    match /staffs/{staffId} {
      // Staff can see each other; public can read for verification.
      allow read, get, list: if true;
      // Allow self-registration if authenticated; Directors manage staff accounts.
      allow create: if isAuthenticated() && request.auth.uid == staffId;
      allow delete: if isDirector();
      allow update: if isOwner(staffId) || isDirector();
    }

    // LEGACY COMPATIBILITY: Support for old collection-based role documents.
    match /directors/{uid} { allow read, write: if isDirector(); }
    match /hods/{uid} { allow read, write: if isHOD(); }
    match /specialists/{uid} { allow read, write: if isSpecialist(); }

    // =========================================================================
    // 3. ACADEMY INFRASTRUCTURE
    // =========================================================================

    // Academy Gate & SSO Backbone: O(1) PIN/Passkey lookup for entry.
    // This MUST remain publicly readable to allow auto-auth from the Main Site.
    match /track_access/{pin} {
      allow read: if true;
      allow create: if true; // Registration creates these
      allow update, delete: if isStaff();
    }

    // Role Codes: One-time use codes for staff onboarding.
    match /role_codes/{code} {
      // Relaxed rules for development: allow onboarding verification.
      allow read: if true;
      allow write: if true; 
    }

    // System Config: Current season and global settings.
    match /system/{docId} {
      allow read: if true;
      allow write: if isDirector();
    }

    // Seasons & Archives: Enrollment data and past generations.
    match /seasons/{seasonId} {
      allow read: if true;
      allow write: if isStaff();
      
      // Allow trainees to update track counters during registration
      match /artifacts/trainees/counters/tracks {
        allow read, write: if true;
      }
      
      // Allow general registration artifacts (referrals, stats, etc)
      match /artifacts/registration/{docId} {
        allow read, write: if true;
      }
      
      match /{document=**} { allow read: if true; allow write: if isStaff(); }
    }

    // Password Management & SSO
    match /password_resets/{id} { allow read, write: if true; }
    match /academy_audit_logs/{id} { allow read: if isStaff(); allow create: if true; }
    match /gate_audit_logs/{id} { allow read: if isStaff(); allow create: if true; }

    // =========================================================================
    // 4. TELEMETRY & LOGS (Publicly Writable, Restricted Read)
    // =========================================================================

    match /presence/{userId} { allow read: if true; allow write: if true; }
    match /tracking/{userId} { allow read: if true; allow write: if true; }
    match /system_faults/{id} { allow read: if isStaff(); allow create: if true; }
    match /audit_logs/{id} { allow read: if isStaff(); allow create: if true; }

    // =========================================================================
    // 5. COMMUNICATIONS & SOCIAL
    // =========================================================================

    match /announcements/{id} { allow read: if true; allow write: if isStaff(); }
    match /mail/{id} { allow read, write: if isAuthenticated(); }
    match /feedback/{id} { allow read: if isStaff(); allow create: if true; }
    match /badge_requests/{id} { 
      allow read: if isStaff() || isOwner(request.resource.data.userId) || isOwner(resource.data.userId);
      allow create: if isAuthenticated();
      allow update: if isStaff();
    }

    // =========================================================================
    // 6. SAFETY NET (TIGHTENED)
    // =========================================================================
    match /{document=**} {
      // Default: Block everything else by default
      allow read, write: if isDirector();
    }
  }
}