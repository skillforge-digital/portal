rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Role-based existence checks
    function inTrainees(uid) { return exists(/databases/$(database)/documents/trainees/$(uid)); }
    function inSpecialists(uid) { return exists(/databases/$(database)/documents/specialists/$(uid)); }
    function inHODs(uid) { return exists(/databases/$(database)/documents/hods/$(uid)); }
    function inDirectors(uid) { return exists(/databases/$(database)/documents/directors/$(uid)); }
    function inStaffs(uid) { return exists(/databases/$(database)/documents/staffs/$(uid)); }

    // Logic for Staff/Director clearance
    function isStaff() {
      return isAuthenticated() && (
        inSpecialists(request.auth.uid) || 
        inHODs(request.auth.uid) || 
        inDirectors(request.auth.uid) || 
        inStaffs(request.auth.uid)
      );
    }

    function isDirector() {
      return isAuthenticated() && (
        inDirectors(request.auth.uid) || 
        (inSpecialists(request.auth.uid) && get(/databases/$(database)/documents/specialists/$(request.auth.uid)).data.level == 'Director') ||
        (inStaffs(request.auth.uid) && get(/databases/$(database)/documents/staffs/$(request.auth.uid)).data.primaryRole == 'Director')
      );
    }

    // ==================== COLLECTION RULES ====================

    // Trainee Registry
    match /trainees/{traineeId} {
      // Allow trainees to see themselves, and staff to see everyone
      allow read: if isAuthenticated() && (isOwner(traineeId) || isStaff());
      
      // Allow creation during registration
      allow create: if isAuthenticated() && isOwner(traineeId);
      
      // Allow updates to self (theme, xp via core) or by staff
      allow update: if isAuthenticated() && (isOwner(traineeId) || isStaff());
      
      // Only directors can delete registry entries
      allow delete: if isDirector();
    }

    // Specialized Personnel Collections
    match /staffs/{uid} {
      allow read: if isAuthenticated();
      allow write: if isDirector() || isOwner(uid);
    }
    match /specialists/{uid} {
      allow read: if isAuthenticated();
      allow write: if isDirector() || isOwner(uid);
    }
    match /hods/{uid} {
      allow read: if isAuthenticated();
      allow write: if isDirector() || isOwner(uid);
    }
    match /directors/{uid} {
      allow read: if isAuthenticated();
      allow write: if isDirector() || isOwner(uid);
    }

    // Academy Core Infrastructure
    match /seasons/{seasonId} {
      allow read: if isAuthenticated();
      allow write: if isDirector();
      
      // Counter synchronization for registration
      match /artifacts/trainees/counters/tracks {
        allow read, create, update: if isAuthenticated(); // Needed for registration transaction
      }

      match /artifacts/trainees/counters/{trackId} {
        allow read, create, update: if isAuthenticated(); // Needed for registration transaction
      }

      match /{document=**} {
        allow read: if isAuthenticated();
        allow write: if isDirector();
      }
    }

    match /system/{docId} {
      allow read: if isAuthenticated();
      allow write: if isDirector();
    }

    // Public/Auth Gate Access
    match /track_access/{pin} {
      allow read: if true; // Public lookup for gate
      allow create: if isAuthenticated(); // Created during registration transaction
      allow update, delete: if isDirector();
    }

    // Analytics, Presence & Faults
    match /presence/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow write: if isAuthenticated() && isOwner(userId);
    }
    match /tracking/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow write: if isAuthenticated() && isOwner(userId);
    }
    match /system_faults/{faultId} {
      allow read: if isStaff();
      allow create: if isAuthenticated();
      allow update, delete: if isDirector();
    }

    // Logs & Feedback
    match /audit_logs/{logId} { allow read, write: if isDirector(); }
    match /academy_audit_logs/{logId} { allow read: if isDirector(); allow create: if isAuthenticated(); }
    match /feedback/{id} { allow read: if isStaff(); allow create: if isAuthenticated(); }
    match /announcements/{id} { allow read: if isAuthenticated(); allow write: if isDirector(); }
    
    match /badge_requests/{requestId} { 
      allow read: if isStaff() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isStaff();
      allow delete: if isDirector();
    }

    // ==================== CATCH-ALL ====================
    match /{document=**} {
      allow read: if isStaff();
      allow write: if isDirector();
    }
  }
}
